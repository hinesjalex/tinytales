OPENAI_MODEL=gpt-4o

# Google (if using)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Image Generation: "nanobanana" (recommended) | "openai"
IMAGE_PROVIDER=nanobanana
IMAGE_RESOLUTION=1K

# fal.ai (for Nano Banana 2)
FAL_KEY=

# OpenAI (if using for text or images)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Stability AI (if using)
STABILITY_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
