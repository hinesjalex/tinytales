# ---- Text AI ----
# AI_PROVIDER: "anthropic" | "openai" | "google"
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (text and/or images)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ---- Image AI ----
# IMAGE_PROVIDER: "nanobanana" (fal.ai) | "openai"
IMAGE_PROVIDER=nanobanana
IMAGE_RESOLUTION=1K

# fal.ai (required for nanobanana)
FAL_KEY=

# ---- Supabase ----
# The anon key is sent to the browser (NEXT_PUBLIC_*) for public reads.
# The service-role key is server-only — never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
