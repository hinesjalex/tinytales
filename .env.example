# AI Provider: "anthropic" | "openai" | "google"
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (if using for text or images)
